# ============================================================
# Radio Apollo - .gitignore
# ============================================================

# ── SECRETS & CREDENTIALS ───────────────────────────────────
serviceAccount.json
key.properties
**/*.keystore
**/*.jks
.env
.env.local
.env.*.local

# ── FLUTTER / DART ──────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.metadata/
build/

# ── ANDROID ─────────────────────────────────────────────────
android/local.properties
android/.gradle/
android/.cxx/
android/captures/
android/gradlew
android/gradlew.bat
**/GeneratedPluginRegistrant.java

# ── iOS ─────────────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/**/DerivedData/
ios/**/xcuserdata/
ios/**/.generated/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
**/dgph
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
**/*sync/
.sconsign.dblite
.tags*
**/.vagrant/
profile

# Keep default Xcode user settings
!default.mode1v3
!default.mode2v3
!default.pbxuser
!default.perspectivev3

# ── macOS ───────────────────────────────────────────────────
macos/Flutter/ephemeral/
macos/Pods/

# ── DEPENDENCIES ────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock

# ── BUILD OUTPUTS ───────────────────────────────────────────
dist/
*.o
*.a
*.so

# ── IDE & EDITORS ───────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS FILES ────────────────────────────────────────────────
.DS_Store
Thumbs.db
Icon?

# ── LOGS ────────────────────────────────────────────────────
*.log
firebase-debug.log
firebase-debug.*.log
npm-debug.log*
yarn-debug.log*

# ── TEMPORARY FILES ─────────────────────────────────────────
tmp/
temp/
*.tmp

# ── PYTHON (if applicable) ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/

# ── TESTING & CACHE ─────────────────────────────────────────
coverage/
.nyc_output/
.cache/
.eslintcache

# Fastlane
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots
ios/fastlane/test_output
ios/fastlane/README.md
ios/fastlane/AuthKey*.p8
ios/fastlane/.env*

# Ruby / Bundler
ios/vendor/
ios/.bundle/
ios/Gemfile.lock

# Build outputs
ios/build/

# Local security testing scripts
*.ps1

# Testing files
test/

lib/functions/test
